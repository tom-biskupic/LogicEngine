{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "gradle-test-debug",
            "type": "shell",
            "command": "gradle test --no-daemon --debug-jvm",
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": ".",
                    "file": 1,
                    "location": 2,
                    "message": 3
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*Starting Gradle Daemon.*|^.*> Task :test.*",
                    "endsPattern": "^.*Listening for transport dt_socket at address: 5005.*"
                }
            }
        }
    ]
}
